{
	"name": "@nsis/highlightjs",
	"version": "0.1.3",
	"description": "highlight.js syntax definition for the NSIS language",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-org.git"
	},
	"homepage": "https://github.com/idleberg/nsis-org/tree/main/packages/highlight.js#readme",
	"keywords": [
		"highlight.js",
		"hljs",
		"highlightjs",
		"nsis"
	],
	"type": "module",
	"exports": {
		".": {
			"types": {
				"import": "./dist/nsis.d.mts",
				"require": "./dist/nsis.d.cts"
			},
			"import": "./dist/nsis.mjs",
			"require": "./dist/nsis.cjs"
		}
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"prepublishOnly": "npm run build",
		"publish:npm": "np",
		"test": "vitest run"
	},
	"devDependencies": {
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"highlight.js": ">=11"
	}
}
