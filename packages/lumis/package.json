{
	"name": "@nsis/lumis",
	"version": "0.1.0",
	"description": "NSIS language support for Lumis syntax highlighter",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/lumis#readme",
	"keywords": [
		"lumis",
		"nsis",
		"syntax-highlighting",
		"tree-sitter"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./language": {
			"import": {
				"types": "./dist/language.d.mts",
				"default": "./dist/language.mjs"
			},
			"require": {
				"types": "./dist/language.d.cts",
				"default": "./dist/language.cjs"
			}
		}
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint:biome": "biome check",
		"prepublishOnly": "npm run build",
		"publish:npm": "np",
		"test": "vitest run"
	},
	"dependencies": {
		"tree-sitter-nsis": "^0.4.0"
	},
	"peerDependencies": {
		"@lumis-sh/lumis": ">=0.1.0"
	},
	"devDependencies": {
		"@lumis-sh/lumis": "^0.5.2",
		"vitest": "catalog:"
	}
}
