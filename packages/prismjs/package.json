{
	"name": "prism-nsis",
	"version": "0.10.0",
	"description": "NSIS support for the PrismJS syntax highlighter",
	"license": "MIT",

	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/prismjs#readme",
	"keywords": [
		"highlighter",
		"nsis",
		"prism",
		"prism.js",
		"syntax highlighter"
	],
	"main": "dist/nsis.js",
	"files:": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"prepublishOnly": "npm run build",
		"publish:npm": "np"
	},
	"devDependencies": {
		"@rollup/plugin-terser": "^0.4.3",
		"@typescript-eslint/eslint-plugin": "^5.60.1",
		"@typescript-eslint/parser": "^5.60.1",
		"eslint": "^8.44.0",
		"eslint-config-recommended": "^4.1.0",
		"retrie": "^0.1.1",
		"rollup": "^3.26.0",
		"rollup-plugin-entry-code-injector": "^1.0.0"
	}
}
