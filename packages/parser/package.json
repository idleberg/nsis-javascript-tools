{
	"name": "@nsis/parser",
	"version": "0.1.0",
	"description": "Parser for NSIS scripts",
	"license": "MIT",
	"scripts": {
		"build": "npm run build:peggy && npm run build:lib",
		"build:lib": "tsdown",
		"build:peggy": "peggy --format es --dts --output src/grammar.js src/grammar.pegjs",
		"dev": "concurrently --prefix-colors blue,green npm:dev:*",
		"dev:lib": "npm run build:lib -- --watch",
		"dev:peggy": "npm run build:peggy -- --watch",
		"lint:biome": "biome check",
		"prepack": "npm run build",
		"pretest": "npm run build:peggy",
		"test": "uvu -r tsm tests"
	},
	"files": [
		"dist/",
		"LICENSE",
		"package.json",
		"README.md"
	],
	"type": "module",
	"typings": "dist/index.d.mts",
	"exports": "./dist/index.mjs",
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/parser#readme",
	"keywords": [
		"nsis",
		"parser",
		"peg",
		"grammar"
	],
	"devDependencies": {
		"peggy": "^5.1.0",
		"tsm": "^2.3.0",
		"uvu": "^0.5.6"
	}
}
