{
	"name": "@nsis/codemirror",
	"version": "0.13.0",
	"description": "NSIS language support for CodeMirror 6",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/codemirror#readme",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"src",
		"LICENSE"
	],
	"scripts": {
		"prebuild": "npm run build:lezer",
		"build": "tsdown",
		"build:lezer": "lezer-generator src/nsis.grammar --output src/parser --typeScript",
		"start": "npm run build:lezer && vite",
		"test": "vitest run",
		"prepare": "npm run build"
	},
	"keywords": [
		"codemirror",
		"lezer",
		"nsis",
		"nullsoft",
		"syntax"
	],
	"dependencies": {
		"@codemirror/autocomplete": "catalog:",
		"@codemirror/language": "catalog:",
		"@lezer/highlight": "catalog:",
		"@lezer/lr": "catalog:"
	},
	"devDependencies": {
		"@lezer/generator": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	}
}
