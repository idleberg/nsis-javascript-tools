{
	"name": "@nsis/dent",
	"version": "0.12.3",
	"description": "An opinionated code formatter for NSIS scripts",
	"license": "MIT",
	"scripts": {
		"build": "tsdown",
		"dev": "npm run build -- --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:biome:ci": "biome ci",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"prepack": "npm run build",
		"publish:jsr": "deno publish",
		"publish:npm": "np",
		"test": "uvu -r tsm tests"
	},
	"files": [
		"dist/",
		"types/",
		"LICENSE",
		"package.json",
		"README.md"
	],
	"type": "module",
	"typings": "dist/dent.d.mts",
	"exports": "./dist/dent.mjs",
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/dent#readme",
	"keywords": [
		"nsis",
		"formatter"
	],
	"dependencies": {
		"@nsis/parser": "workspace:*",
		"detect-newline": "^4.0.1"
	},
	"devDependencies": {
		"tsm": "^2.3.0",
		"uvu": "^0.5.6"
	}
}
