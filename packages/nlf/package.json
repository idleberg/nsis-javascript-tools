{
	"name": "@nsis/nlf",
	"version": "0.13.0",
	"description": "Parser and stringifier for NSIS Language Files",
	"license": "MIT",
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:biome:ci": "biome ci",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"prepack": "npm run build",
		"publish:npm": "np --any-branch",
		"test": "uvu -r tsm tests"
	},
	"files": [
		"dist/",
		"types/",
		"LICENSE",
		"README.md"
	],
	"type": "module",
	"exports": "./dist/index.mjs",
	"typings": "./dist/index.d.mts",
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/nsis-javascript-tools.git"
	},
	"homepage": "https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/nlf#readme",
	"keywords": [
		"nsis",
		"nsis language file",
		"converter"
	],
	"dependencies": {
		"json5": "^2.2.3"
	},
	"devDependencies": {
		"glob": "^11.0.3",
		"tsm": "^2.3.0",
		"uvu": "^0.5.6"
	}
}
