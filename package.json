{
	"name": "@nsis/highlight.js",
	"version": "0.0.0",
	"description": "highlight.js syntax definition for the NSIS language",
	"license": "BSD-3-Clause",
	"repository": {
		"type": "git",
		"url": "https://github.com/highlightjs/highlightjs-nsis.git"
	},
	"keywords": [
		"highlight.js",
		"hljs",
		"highlightjs",
		"nsis"
	],
	"type": "module",
	"exports": {
		".": {
			"types": {
				"import": "./dist/nsis.d.mts",
				"require": "./dist/nsis.d.cts"
			},
			"import": "./dist/nsis.mjs",
			"require": "./dist/nsis.cjs"
		}
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "concurrently --prefix-colors blue,green,magenta npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze --log-level error",
		"prepublishOnly": "npm run build",
		"publish:npm": "np",
		"test": "vitest run"
	},
	"peerDependencies": {
		"highlight.js": ">=11"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@idleberg/configs": "^0.4.5",
		"@types/node": "^25.9.2",
		"concurrently": "^10.0.3",
		"highlight.js": "^11.11.0",
		"np": "^11.2.1",
		"tsdown": "^0.22.2",
		"vitest": "^4.1.8"
	},
	"packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
