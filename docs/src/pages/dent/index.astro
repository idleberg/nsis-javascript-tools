---
import example from '../../data/misformatted.nsi?raw';
import '../global.css';

const focusRing = 'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
		<meta name="description" content="An opinionated code formatter for NSIS scripts" />
		<title>Demo | @nsis/dent</title>
	</head>

	<body class="flex flex-col bg-grey-lighter dark:bg-gray-800 min-h-screen p-4 font-sans">
		<main class="container mx-auto">
			<div class="mx-auto w-full lg:w-2/3">
				<h1 class="text-2xl tracking-tight text-gray-900">
					<span class="block xl:inline">@nsis/dent</span>
				</h1>

				<p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg md:mt-5 md:text-xl">
					An opinionated code formatter for <a class:list={["text-indigo-600", focusRing]} href="https://nsis.sourceforge.io">NSIS</a> scripts.
				</p>

				<div class="mt-8 lg:mt-5">
					<fieldset>
						<legend class="font-semibold text-gray-900">Settings</legend>
						<div class="mt-3 flex flex-wrap gap-x-6 gap-y-3">
							<label class="flex items-center gap-2 text-sm text-gray-700">
								<input type="checkbox" id="useTabs" checked class:list={["accent-indigo-600", focusRing]} />
								Use tabs
							</label>
							<label class="flex items-center gap-2 text-sm text-gray-700">
								<input type="checkbox" id="singleQuote" class:list={["accent-indigo-600", focusRing]} />
								Single quotes
							</label>
							<label class="flex items-center gap-2 text-sm text-gray-700">
								<input type="checkbox" id="trimEmptyLines" checked class:list={["accent-indigo-600", focusRing]} />
								Trim empty lines
							</label>
							<label class="flex items-center gap-2 text-sm text-gray-700">
								Indent size
								<select id="indentSize" class:list={["border border-gray-300 rounded px-2 py-1 text-sm", focusRing]}>
									<option value="2" selected>2</option>
									<option value="4">4</option>
									<option value="8">8</option>
								</select>
							</label>
							<label class="flex items-center gap-2 text-sm text-gray-700">
								Print width
								<input type="number" id="printWidth" value="120" min="40" max="320" step="10" class:list={["border border-gray-300 rounded px-2 py-1 text-sm w-20", focusRing]} />
							</label>
							<label class="flex items-center gap-2 text-sm text-gray-700">
								End of line
								<select id="endOfLine" class:list={["border border-gray-300 rounded px-2 py-1 text-sm", focusRing]}>
									<option value="lf" selected>LF</option>
									<option value="crlf">CRLF</option>
								</select>
							</label>
						</div>
					</fieldset>
				</div>
			</div>

			<div class="mx-auto w-full max-w-screen-xl mt-6">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
					<div class="min-w-0">
						<span class="font-semibold text-gray-900">Input</span>
						<div id="inputEditor" class="mt-2 rounded overflow-hidden h-[48rem]" role="textbox" aria-label="Input" aria-multiline="true"></div>
					</div>
					<div class="min-w-0">
						<span class="font-semibold text-gray-900">Output</span>
						<div class="relative mt-2">
							<div id="outputEditor" class="rounded overflow-hidden h-[48rem]" role="textbox" aria-label="Formatted output" aria-multiline="true" aria-readonly="true"></div>
							<button
								id="copyBtn"
								type="button"
								class:list={["absolute top-3 right-4 z-10 p-1.5 rounded text-gray-500 hover:text-gray-300 hover:bg-gray-700 transition-colors cursor-pointer hidden", focusRing]}
								aria-label="Copy to clipboard"
								title="Copy to clipboard"
							>
								<svg id="copyIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
									<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
								</svg>
								<svg id="checkIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="20 6 9 17 4 12"></polyline>
								</svg>
							</button>
						</div>
					</div>
				</div>
			</div>

			<div class="mx-auto w-full lg:w-2/3">
				<div class="mt-4 flex items-center gap-3">
					<button
						id="formatBtn"
						type="button"
						class:list={["px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded hover:bg-indigo-700 transition-colors cursor-pointer", focusRing]}
					>
						Format
					</button>
					<button
						id="clearBtn"
						type="button"
						class:list={["px-4 py-2 bg-gray-200 text-gray-700 text-sm font-medium rounded hover:bg-gray-300 transition-colors cursor-pointer", focusRing]}
					>
						Clear
					</button>
					<label class="flex items-center gap-2 text-sm text-gray-700 ml-2">
						<input type="checkbox" id="autoFormat" checked class:list={["accent-indigo-600", focusRing]} />
						Auto-format
					</label>
				</div>
				<div id="autoFormatStatus" class="sr-only" aria-live="polite"></div>

				<div id="error" class="mt-3 hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded text-sm" role="alert"></div>
			</div>
		</main>

		<footer class="w-full text-center p-4 pin-b">
			<a href="https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/dent" class:list={["text-indigo-600", focusRing]}>Code on GitHub</a>
		</footer>
	</body>
</html>

<script is:inline define:vars={{ example }}>
	window.__NSIS_EXAMPLE__ = example;
</script>

<script>
	import { createFormatter } from '@nsis/dent';
	import { EditorState } from '@codemirror/state';

	const uad = (navigator as Navigator & { userAgentData?: { platform: string } }).userAgentData;
	const isWindows = uad?.platform === 'Windows'
		|| (!uad && /Win/.test(navigator.platform));

	if (isWindows) {
		const eolSelect = document.getElementById('endOfLine') as HTMLSelectElement;
		eolSelect.value = 'crlf';
	}
	import { EditorView, keymap } from '@codemirror/view';
	import { defaultKeymap, history, historyKeymap } from '@codemirror/commands';
	import { nsisLanguage } from '@nsis/codemirror';
	import { oneDark } from '@codemirror/theme-one-dark';

	const editorTheme = EditorView.theme({
		'&': { height: '100%', fontSize: '0.875rem' },
		'.cm-scroller': { overflow: 'auto', fontFamily: 'ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace' },
		'.cm-content': { padding: '0.75rem 0' },
		'.cm-line': { padding: '0 0.75rem' },
	});

	const commonExtensions = [
		oneDark,
		editorTheme,
	];

	let debounceTimer: ReturnType<typeof setTimeout>;
	function scheduleAutoFormat() {
		const checkbox = document.getElementById('autoFormat') as HTMLInputElement;
		if (!checkbox.checked) return;
		clearTimeout(debounceTimer);
		debounceTimer = setTimeout(() => {
			formatInput();
			updateCopyButton();
			const status = document.getElementById('autoFormatStatus')!;
			status.textContent = 'Output updated';
			setTimeout(() => { status.textContent = ''; }, 1000);
		}, 500);
	}

	const inputView = new EditorView({
		state: EditorState.create({
			doc: (window as any).__NSIS_EXAMPLE__,
			extensions: [
				...commonExtensions,
				history(),
				keymap.of([...defaultKeymap, ...historyKeymap]),
				EditorView.updateListener.of((update) => {
					if (update.docChanged) scheduleAutoFormat();
				}),
			],
		}),
		parent: document.getElementById('inputEditor')!,
	});

	const outputView = new EditorView({
		state: EditorState.create({
			doc: '',
			extensions: [
				...commonExtensions,
				nsisLanguage,
				EditorState.readOnly.of(true),
				EditorView.editable.of(false),
			],
		}),
		parent: document.getElementById('outputEditor')!,
	});

	const errorEl = document.getElementById('error') as HTMLDivElement;
	const formatBtn = document.getElementById('formatBtn') as HTMLButtonElement;
	const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
	const copyBtn = document.getElementById('copyBtn') as HTMLButtonElement;
	const copyIcon = document.getElementById('copyIcon') as HTMLElement;
	const checkIcon = document.getElementById('checkIcon') as HTMLElement;

	function getOptions() {
		return {
			useTabs: (document.getElementById('useTabs') as HTMLInputElement).checked,
			singleQuote: (document.getElementById('singleQuote') as HTMLInputElement).checked,
			trimEmptyLines: (document.getElementById('trimEmptyLines') as HTMLInputElement).checked,
			indentSize: Number((document.getElementById('indentSize') as HTMLSelectElement).value),
			printWidth: Number((document.getElementById('printWidth') as HTMLInputElement).value),
			endOfLine: (document.getElementById('endOfLine') as HTMLSelectElement).value as 'lf' | 'crlf',
		};
	}

	function setOutput(text: string) {
		outputView.dispatch({
			changes: { from: 0, to: outputView.state.doc.length, insert: text },
		});
	}

	function formatInput() {
		errorEl.textContent = '';
		errorEl.classList.add('hidden');

		const source = inputView.state.doc.toString();
		if (!source.trim()) {
			setOutput('');
			return;
		}

		try {
			const { format } = createFormatter(getOptions());
			setOutput(format(source));
		} catch (err) {
			errorEl.textContent = err instanceof Error ? err.message : String(err);
			errorEl.classList.remove('hidden');
		}
	}

	function updateCopyButton() {
		copyBtn.classList.toggle('hidden', outputView.state.doc.length === 0);
	}

	const settingIds = ['useTabs', 'singleQuote', 'trimEmptyLines', 'indentSize', 'printWidth', 'endOfLine'];
	for (const id of settingIds) {
		document.getElementById(id)!.addEventListener('change', scheduleAutoFormat);
	}

	formatBtn.addEventListener('click', () => {
		formatInput();
		updateCopyButton();
	});

	clearBtn.addEventListener('click', () => {
		clearTimeout(debounceTimer);
		inputView.dispatch({
			changes: { from: 0, to: inputView.state.doc.length, insert: '' },
		});
		setOutput('');
		errorEl.textContent = '';
		errorEl.classList.add('hidden');
		updateCopyButton();
	});

	copyBtn.addEventListener('click', async () => {
		await navigator.clipboard.writeText(outputView.state.doc.toString());
		copyIcon.classList.add('hidden');
		checkIcon.classList.remove('hidden');
		setTimeout(() => {
			copyIcon.classList.remove('hidden');
			checkIcon.classList.add('hidden');
		}, 1500);
	});

	scheduleAutoFormat();
</script>
