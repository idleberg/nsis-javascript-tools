---
import modeUrl from '@nsis/ace-mode/dist/mode-nsis.noconflict.js?url';
import example from '../../data/example.nsi?raw';
import DemoLayout from '../../layouts/DemoLayout.astro';
---

<DemoLayout
	title="Demo | @nsis/ace-mode"
	description="NSIS mode for Ace Editor"
	packageName="@nsis/ace-mode"
	footerUrl="https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/ace-mode"
>
	<Fragment slot="head">
		<style>
			#editor {
				width: 100%;
				height: 580px;
				border: 1px solid;
			}
		</style>

		<script defer src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.7.1/ace.min.js" integrity="sha512-7Jmn5XgQKvX7kd2yARvOywZYQfC6eB7WLLdpWfGifPHe+93PwGf2BpkrX/vPRgPxllivNDnD8TSMHpYb60opMg==" crossorigin="anonymous" referrerpolicy="no-referrer" is:inline></script>
		<script defer src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.7.1/theme-nord_dark.min.js" integrity="sha512-DL7jU9qDTsdJtyh2Kqm/dZp9w5Kkb7eiwOH7jC8Z9qfyQIXCtc+YA6uVz2uOcutNt5+zVzOO5hDK6C1pYOnTmQ==" crossorigin="anonymous" referrerpolicy="no-referrer" is:inline></script>

		<script defer src={modeUrl} is:inline></script>

		<script is:inline>
			window.addEventListener('DOMContentLoaded', () => {
				ace.config.set('basePath', 'https://cdnjs.cloudflare.com/ajax/libs/ace/1.7.1/');
				const editor = ace.edit("editor");
				editor.setTheme("ace/theme/nord_dark");
				editor.setOptions({
					fontSize: "1em",
					maxLines: Infinity
				});
				editor.setShowPrintMargin(false);
				editor.session.setMode("ace/mode/nsis");
			});
		</script>
	</Fragment>

	<Fragment slot="description">
		A mode for <a class="text-indigo-600" href="https://nsis.sourceforge.io">NSIS</a> to use with <a class="text-indigo-600" href="https://ace.c9.io/">Ace</a>, an embeddable code editor written in JavaScript.
	</Fragment>

	<div slot="example" id="editor" class="mt-3" set:text={example} />
</DemoLayout>
