---
import modeUrl from '@nsis/ace-mode/dist/mode-nsis.noconflict.js?url';
import example from '../../data/example.nsi?raw';
import DemoLayout from '../../layouts/DemoLayout.astro';
---

<DemoLayout
	title="Demo | @nsis/ace-mode"
	description="NSIS mode for Ace Editor"
	packageName="@nsis/ace-mode"
	footerUrl="https://github.com/idleberg/nsis-javascript-tools/tree/main/packages/ace-mode"
>
	<Fragment slot="head">
		<style>
			#editor {
				width: 100%;
				height: 580px;
				border: 1px solid;
			}
		</style>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.43.3/ace.min.js" integrity="sha512-BHJlu9vUXVrcxhRwbBdNv3uTsbscp8pp3LJ5z/sw9nBJUegkNlkcZnvODRgynJWhXMCsVUGZlFuzTrr5I2X3sQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.43.3/theme-one_dark.min.js" integrity="sha512-IzwM6BfvrK5Yt8SGQXeP/k6CHHMQRsjHHiqf3txqNuAA1fOIZa1aQEWBsY9X+X+xF60e8xuSIQbNhmFmiaxs4Q==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

		<script defer src={modeUrl} is:inline></script>

		<script is:inline>
			window.addEventListener('DOMContentLoaded', () => {
				ace.config.set('basePath', 'https://cdnjs.cloudflare.com/ajax/libs/ace/1.43.3/');
				const editor = ace.edit("editor");
				editor.setTheme("ace/theme/one_dark");
				editor.setOptions({
					fontSize: "1em",
					maxLines: Infinity
				});
				editor.setShowPrintMargin(false);
				editor.session.setMode("ace/mode/nsis");
			});
		</script>
	</Fragment>

	<Fragment slot="description">
		A mode for <a class="text-indigo-600" href="https://nsis.sourceforge.io">NSIS</a> to use with <a class="text-indigo-600" href="https://ace.c9.io/">Ace</a>, an embeddable code editor written in JavaScript.
	</Fragment>

	<div slot="example" id="editor" class="mt-3" set:text={example} />
</DemoLayout>
